{
  "name": "guzo-go",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise-grade logistics & delivery platform (modular monolith) - SF Express / FedEx / DHL style. Local-first, free & open-source, cloud-ready.",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "node scripts/dev-all.mjs",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:stop": "powershell -ExecutionPolicy Bypass -File scripts/dev-stop.ps1",
    "dev:server": "npm run dev --workspace @delivery/server",
    "dev:server:java": "powershell -ExecutionPolicy Bypass -File scripts/dev-java-api.ps1",
    "dev:web": "npm run dev --workspace @guzo/web",
    "dev:marketing": "npm run dev --workspace @guzo/marketing",
    "dev:mobile-customer": "npm run start --workspace @guzo/mobile-customer",
    "dev:mobile-driver": "npm run start --workspace @guzo/mobile-driver",
    "dev:mobile-merchant": "npm run start --workspace @guzo/mobile-merchant",
    "dev:mobile-branch": "npm run start --workspace @guzo/mobile-branch",
    "dev:mobile:phone": "powershell -ExecutionPolicy Bypass -File scripts/dev-mobile-phone.ps1",
    "mobile:qr": "powershell -ExecutionPolicy Bypass -File scripts/generate-mobile-qrs.ps1",
    "mobile:brand": "powershell -ExecutionPolicy Bypass -File scripts/sync-mobile-brand.ps1",
    "mobile:splash": "powershell -ExecutionPolicy Bypass -File scripts/generate-mobile-splash.ps1",
    "eas:customer:preview": "npm run eas:preview --workspace @guzo/mobile-customer",
    "eas:customer:prod": "npm run eas:prod --workspace @guzo/mobile-customer",
    "eas:driver:preview": "npm run eas:preview --workspace @guzo/mobile-driver",
    "eas:merchant:preview": "npm run eas:preview --workspace @guzo/mobile-merchant",
    "eas:driver:prod": "npm run eas:prod --workspace @guzo/mobile-driver",
    "eas:merchant:prod": "npm run eas:prod --workspace @guzo/mobile-merchant",
    "build:mobile:android": "powershell -ExecutionPolicy Bypass -File scripts/build-mobile.ps1 -Platform android",
    "build:mobile:ios": "powershell -ExecutionPolicy Bypass -File scripts/build-mobile.ps1 -Platform ios",
    "build:mobile:all": "powershell -ExecutionPolicy Bypass -File scripts/build-mobile.ps1 -Platform all",
    "copy:mobile-builds": "powershell -ExecutionPolicy Bypass -File scripts/copy-mobile-builds.ps1",
    "postinstall": "powershell -ExecutionPolicy Bypass -File scripts/fix-metro-watch.ps1",
    "typecheck:mobile": "npm run typecheck --workspace @guzo/mobile-shared && npm run typecheck --workspace @guzo/mobile-ui && npm run typecheck --workspace @guzo/mobile-customer && npm run typecheck --workspace @guzo/mobile-driver && npm run typecheck --workspace @guzo/mobile-merchant && npm run typecheck --workspace @guzo/mobile-branch",
    "eas:setup": "powershell -ExecutionPolicy Bypass -File scripts/eas-setup.ps1",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "npm run generate --workspace @delivery/database",
    "db:migrate": "npm run migrate --workspace @delivery/database",
    "db:seed": "npm run seed --workspace @delivery/database",
    "db:studio": "npm run studio --workspace @delivery/database",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "push:day": "powershell -ExecutionPolicy Bypass -File scripts/push-git-day.ps1",
    "git:setup-week": "powershell -ExecutionPolicy Bypass -File scripts/setup-git-week.ps1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "concurrently": "^9.2.3",
    "eas-cli": "^16.17.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.10",
    "react-native": {
      "@types/react": "~19.1.10"
    },
    "@react-native/virtualized-lists": {
      "@types/react": "~19.1.10"
    },
    "ajv-keywords": {
      "ajv": "^8.17.1"
    },
    "ajv": "^8.17.1"
  }
}
