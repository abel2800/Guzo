# Copy to .env at the repository root or apps/server/.env (never commit .env)

NODE_ENV=development
APP_NAME=DeliveryPlatform
API_VERSION=v1
PORT=4010
HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:4010

CORS_ORIGINS=http://localhost:3000,http://localhost:3001

DATABASE_URL=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SEED_DEMO_PASSWORD=

REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

STORAGE_DRIVER=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

EMAIL_DRIVER=console
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

OSRM_BASE_URL=https://router.project-osrm.org
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

PAYMENT_PROVIDER=fake
SMS_DRIVER=console
PUSH_DRIVER=expo

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
LOG_LEVEL=debug
